# Layer-0 PII-scan exemptions (pathspec patterns), consumed by .git/hooks/pre-commit.
#
# These are PUBLIC-BY-LAW legal-disclosure pages. An Austrian Impressum must
# show the GISA-Zahl (8-digit, trips the phone-like check) and a business
# contact email (trips the email check) per §5 ECG / §63 GewO / §25 MedienG.
# The personal phone number is deliberately omitted (see ai-brain 00g). The
# Layer-0 guard stays active across the rest of the repo.
src/components/LegalImpressumDE.tsx
src/components/LegalImpressumEN.tsx
src/components/LegalPrivacyDE.tsx
src/components/LegalPrivacyEN.tsx

# All documentation — specs, plans, offer/landing copy, brand notes. These
# intentionally carry GISA/contact references, native currency amounts, and
# date/ID digit runs by design (internal/by-design surfaces, not shipped code).
# Exempt the whole tree so new docs (docs/superpowers/, docs/offers/, …) are
# never missed. Trade-off: the email/phone/deny-name scan is also off under
# docs/ — acceptable for internal docs. The Layer-0 guard stays active elsewhere.
docs/

# Contact API route hardcodes the studio's own PUBLIC recipient address
# (the same hallo@ business inbox published on the Impressum) as the
# sendMail destination — not third-party PII.
src/app/api/contact/route.ts

# Website-Check offer surface carries the productized fixed price (a native
# Euro amount) and its schema.org Offer markup (which requires the ISO
# priceCurrency code) as intentional public marketing content — the same kind
# of public price already shown on the Pension/Direktbucher landing. The price
# is isolated to these two offer files (not the shared copy dictionary), so the
# Layer-0 currency/PII scan stays active over all other site copy.
src/components/WebsiteCheck.tsx
src/components/WebsiteCheckJsonLd.tsx

# Homepage offer band surfaces the two productized entry offers with their
# public fixed prices (Website-Check + Direktbucher). Same rationale as above:
# prices are intentional public marketing figures, isolated to this one
# component (not the shared copy dictionary).
src/components/HomeOffers.tsx
